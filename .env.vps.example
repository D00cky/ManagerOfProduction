# Copy to .env.vps and replace every secret before deployment.
# IMPORTANT: docker-compose.traefik.yml builds DATABASE_URL from POSTGRES_PASSWORD,
# so the password is embedded in a URL. Use a URL-safe value with NO special
# characters (/, :, @, +, =) — generate one with:  openssl rand -hex 24
# A base64 password (openssl rand -base64) will break the URL (Prisma P1013).
POSTGRES_PASSWORD=replace-with-a-url-safe-hex-password
# DATABASE_URL below is unused by docker-compose.traefik.yml (it is built from
# POSTGRES_PASSWORD); kept for reference / local non-Docker runs.
DATABASE_URL=postgresql://manager:replace-with-a-url-safe-hex-password@postgres:5432/manager_of_production?schema=public
REDIS_URL=redis://redis:6379
NEXTAUTH_URL=https://your-domain.example
NEXTAUTH_SECRET=replace-with-a-long-random-secret
BACKUP_LOCAL_DIR=/backups

# Traefik (docker-compose.traefik.yml)
DOMAIN=your-domain.example
ACME_EMAIL=you@example.com

DEMO_AUTH_ENABLED=false
DEMO_AUTH_PASSWORD=replace-or-remove-this-demo-password
