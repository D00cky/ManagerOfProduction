# VPS deployment config. Copy to .env.vps and fill in real values (never commit it).
# Set NEXTAUTH_URL to the public origin (prefer https:// behind a domain so the
# session cookie is sent with the Secure flag and credentials are not in cleartext).
DATABASE_URL=file:/data/prod.db
NEXTAUTH_URL=https://your-domain.example
NEXTAUTH_SECRET=replace-with-a-long-random-secret
BACKUP_LOCAL_DIR=/backups

# Keep demo auth off by default for VPS persistence.
# Set true only if you want the built-in demo credentials to work without DB users.
DEMO_AUTH_ENABLED=false
DEMO_AUTH_PASSWORD=senha123
RESET_DEMO_DB_ON_START=false
