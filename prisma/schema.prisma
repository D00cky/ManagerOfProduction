generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  fiscal
  monitor
  supervisor
}

enum StatusUsuario {
  ativo
  inativo
}

enum StatusOS {
  NaFila
  EmExecucao
  Pendente
  Concluida
  Cancelada
}

enum TipoServico {
  LigacaoAgua
  ReligacaoAgua
  CorteAgua
  TrocaHidrometro
  Vistoria
  ReparoRede
  Outros
}

enum Conceito {
  A
  B
  C
  D
  NaoAvaliado
}

enum EventoLog {
  importacao
  atribuicao
  reatribuicao
  status
  tabulacao
  exclusao
  usuario
  sync
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  matricula    String           @unique
  passwordHash String
  perfil       Perfil
  status       StatusUsuario    @default(ativo)
  poloId       String?
  polo         Polo?            @relation(fields: [poloId], references: [id])
  regiao       String?
  lastSeenAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  acessosPolo  UserPoloAccess[]
  ordensFiscal OrdemServico[]   @relation("FiscalOS")
  tabulacoes   Tabulacao[]
  tabuladas    Tabulacao[]      @relation("TabuladoPor")
  alteradas    Tabulacao[]      @relation("AlteradoPor")
  avaliacoes   Avaliacao[]
  logs         LogAtividade[]
}

model Polo {
  id        String           @id @default(cuid())
  nome      String           @unique
  codigo    String           @unique
  regiao    String?
  ativo     Boolean          @default(true)
  users     User[]
  acessos   UserPoloAccess[]
  ordens    OrdemServico[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([regiao])
}

model UserPoloAccess {
  id        String   @id @default(cuid())
  userId    String
  poloId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  polo      Polo     @relation(fields: [poloId], references: [id], onDelete: Cascade)

  @@unique([userId, poloId])
}

model OrdemServico {
  id                   String         @id @default(cuid())
  numero               String         @unique
  enderecoCompleto     String
  numeroImovel         String?
  complemento          String?
  bairro               String?
  cidade               String?
  regiaoAdministrativa String?
  tipoServico          TipoServico
  status               StatusOS       @default(NaFila)
  poloId               String
  fiscalId             String?
  unidadeExecutante    String?
  codigoContrato       String?
  descricaoContrato    String?
  codigoTss            String?
  descricaoTss         String?
  codigoTse            String?
  descricaoTse         String?
  pde                  String?
  equipe               String?
  observacao           String?
  dataProgramada       DateTime?
  dataInicioExecucao   DateTime?
  dataFimExecucao      DateTime?
  iniciadaEm           DateTime?
  concluidaEm          DateTime?
  canceladaEm          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  polo                 Polo           @relation(fields: [poloId], references: [id])
  fiscal               User?          @relation("FiscalOS", fields: [fiscalId], references: [id])
  tabulacao            Tabulacao?
  logs                 LogAtividade[]

  @@index([fiscalId, status])
  @@index([poloId, status, fiscalId, dataProgramada, createdAt])
  @@index([createdAt])
  @@index([regiaoAdministrativa, cidade])
  @@index([regiaoAdministrativa, status, createdAt])
  @@index([concluidaEm])
  @@index([status, updatedAt])
  @@index([fiscalId, status, concluidaEm])
  @@index([poloId, tipoServico])
}

model Tabulacao {
  id              String       @id @default(cuid())
  ordemServicoId  String       @unique
  fiscalId        String
  tabuladoPorId   String?
  respostas       Json
  somaObtida      Float
  somaPossivel    Float
  percentual      Float
  conceito        Conceito
  observacoes     String?
  bloqueada       Boolean      @default(false)
  alterada        Boolean      @default(false)
  alteradoPorId   String?
  motivoAlteracao String?
  alteradaEm      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  ordemServico    OrdemServico @relation(fields: [ordemServicoId], references: [id])
  fiscal          User         @relation(fields: [fiscalId], references: [id])
  tabuladoPor     User?        @relation("TabuladoPor", fields: [tabuladoPorId], references: [id])
  alteradoPor     User?        @relation("AlteradoPor", fields: [alteradoPorId], references: [id])
  avaliacoes      Avaliacao[]

  @@index([fiscalId])
  @@index([createdAt])
}

model Avaliacao {
  id          String    @id @default(cuid())
  tabulacaoId String
  avaliadorId String
  nota        Int
  comentario  String?
  createdAt   DateTime  @default(now())
  tabulacao   Tabulacao @relation(fields: [tabulacaoId], references: [id])
  avaliador   User      @relation(fields: [avaliadorId], references: [id])
}

model LogAtividade {
  id             String        @id @default(cuid())
  evento         EventoLog
  descricao      String
  metadata       Json?
  userId         String?
  ordemServicoId String?
  createdAt      DateTime      @default(now())
  user           User?         @relation(fields: [userId], references: [id])
  ordemServico   OrdemServico? @relation(fields: [ordemServicoId], references: [id])

  @@index([ordemServicoId])
  @@index([userId])
  @@index([createdAt])
}

model ConfigSync {
  id           String   @id @default(cuid())
  caminhoRede  String?
  intervaloMin Int      @default(60)
  formato      String   @default("ambos")
  autoBackup   Boolean  @default(true)
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BackupRegistro {
  id        String   @id @default(cuid())
  destino   String
  formato   String
  caminho   String
  sucesso   Boolean
  mensagem  String?
  createdAt DateTime @default(now())
}
